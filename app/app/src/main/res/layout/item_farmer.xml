<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:background="@color/card_bg"
    android:gravity="center_vertical">

    <!-- Farmer Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/tv_farmer_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="F001"
                android:textSize="12sp"
                android:textColor="@color/primary"
                android:background="@drawable/badge_primary"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:layout_marginEnd="8dp"/>
            <TextView
                android:id="@+id/tv_farmer_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Farmer Name"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_farmer_phone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="9999999999"
            android:textSize="13sp"
            android:textColor="@color/text_muted"
            android:layout_marginTop="2dp"/>

        <TextView
            android:id="@+id/tv_farmer_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2 Cows / 3 Buffaloes · 15L/day"
            android:textSize="12sp"
            android:textColor="@color/text_muted"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <!-- Delete Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_delete"
        style="@Widget.Material3.Button.IconButton"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:padding="0dp"
        app:icon="@drawable/ic_delete"
        app:iconTint="@color/danger"
        android:backgroundTint="@color/danger_light"
        android:contentDescription="Delete Farmer"
        xmlns:app="http://schemas.android.com/apk/res-auto"/>
</LinearLayout>
