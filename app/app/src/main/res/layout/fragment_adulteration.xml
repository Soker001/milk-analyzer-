<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_color"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Contamination Check Card -->
        <com.google.android.material.card.MaterialCardView
            style="@style/DairyDash.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Title -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_microscope"
                        android:tint="@color/primary"
                        android:layout_marginEnd="8dp"/>
                    <TextView
                        style="@style/DairyDash.SectionTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/contamination_check"/>
                </LinearLayout>

                <!-- Water Dilution + pH -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/DairyDash.TextInputLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:layout_marginBottom="12dp"
                        android:hint="@string/label_water_dilution">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_water"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:text="0"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/DairyDash.TextInputLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:layout_marginBottom="12dp"
                        android:hint="@string/label_ph">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_ph"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:text="6.6"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Urea + Starch -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/DairyDash.ExposedDropdown"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:layout_marginBottom="12dp"
                        android:hint="@string/label_urea">
                        <AutoCompleteTextView
                            android:id="@+id/spinner_urea"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:text="No"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/DairyDash.ExposedDropdown"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:layout_marginBottom="12dp"
                        android:hint="@string/label_starch">
                        <AutoCompleteTextView
                            android:id="@+id/spinner_starch"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:text="No"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Detergent + Salt -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/DairyDash.ExposedDropdown"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:layout_marginBottom="20dp"
                        android:hint="@string/label_detergent">
                        <AutoCompleteTextView
                            android:id="@+id/spinner_detergent"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:text="No"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/DairyDash.ExposedDropdown"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:layout_marginBottom="20dp"
                        android:hint="@string/label_salt">
                        <AutoCompleteTextView
                            android:id="@+id/spinner_salt"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:text="No"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Generate Score Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_generate_score"
                    style="@style/DairyDash.Button.Warning"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_generate_final_score"
                    android:padding="14dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Final Analysis Result Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_result"
            style="@style/DairyDash.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    style="@style/DairyDash.SectionTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/final_analysis"
                    android:layout_marginBottom="16dp"/>

                <!-- Final Score Display -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_surface"
                    android:padding="20dp"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/final_quality_score"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_muted"/>
                    <TextView
                        android:id="@+id/tv_final_score"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="56sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

                <!-- Status Alert -->
                <TextView
                    android:id="@+id/tv_adulteration_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pure Milk"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/alert_pure"/>

                <!-- Warning Messages -->
                <LinearLayout
                    android:id="@+id/ll_warnings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp"/>

                <!-- Proceed to Payment -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_proceed_payment"
                    style="@style/DairyDash.Button.Success"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_proceed_payment"
                    android:padding="14dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
