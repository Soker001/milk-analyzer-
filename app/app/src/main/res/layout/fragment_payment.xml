<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_color"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Smart Pricing Form Card -->
        <com.google.android.material.card.MaterialCardView
            style="@style/DairyDash.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Title -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_payment"
                        android:tint="@color/primary"
                        android:layout_marginEnd="8dp"/>
                    <TextView
                        style="@style/DairyDash.SectionTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/smart_pricing"/>
                </LinearLayout>

                <!-- State Dropdown -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/DairyDash.ExposedDropdown"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:hint="@string/label_select_state">
                    <AutoCompleteTextView
                        android:id="@+id/spinner_state"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:text="@string/select_state_hint"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Data Summary Box -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/bg_dashed"
                    android:padding="15dp"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/data_from_analysis"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_main"
                        android:layout_marginBottom="12dp"/>

                    <!-- Qty + Fat -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/quantity_label"
                                android:textSize="13sp"
                                android:textColor="@color/text_muted"/>
                            <TextView
                                android:id="@+id/tv_summary_qty"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 L"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_dark"/>
                        </LinearLayout>
                        <View android:layout_width="16dp" android:layout_height="1dp"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/fat_label"
                                android:textSize="13sp"
                                android:textColor="@color/text_muted"/>
                            <TextView
                                android:id="@+id/tv_summary_fat"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 %"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_dark"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- SNF + Score -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/snf_label"
                                android:textSize="13sp"
                                android:textColor="@color/text_muted"/>
                            <TextView
                                android:id="@+id/tv_summary_snf"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 %"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_dark"/>
                        </LinearLayout>
                        <View android:layout_width="16dp" android:layout_height="1dp"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/quality_score_label"
                                android:textSize="13sp"
                                android:textColor="@color/text_muted"/>
                            <TextView
                                android:id="@+id/tv_summary_score"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 / 100"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_dark"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Calculate Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_calculate"
                    style="@style/DairyDash.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/btn_calculate_payout"
                    android:padding="14dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Payment Result Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_payment_result"
            style="@style/DairyDash.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    style="@style/DairyDash.SectionTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/payment_overview"
                    android:layout_marginBottom="16dp"/>

                <!-- Loading -->
                <LinearLayout
                    android:id="@+id/ll_loading"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:padding="20dp"
                    android:visibility="gone">
                    <ProgressBar
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="12dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/calculating"
                        android:textColor="@color/text_muted"/>
                </LinearLayout>

                <!-- Payment Details -->
                <LinearLayout
                    android:id="@+id/ll_payment_details"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <!-- Formula Box -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_formula"
                        android:padding="15dp"
                        android:layout_marginBottom="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/formula_used"
                            android:textSize="12sp"
                            android:textColor="@color/text_muted"
                            android:layout_marginBottom="4dp"/>
                        <TextView
                            android:id="@+id/tv_formula"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Select a state"
                            android:textSize="13sp"
                            android:textColor="@color/text_dark"
                            android:fontFamily="monospace"/>
                    </LinearLayout>

                    <!-- Price Breakdown -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="20dp">

                        <!-- Base Price Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/base_price_per_l"
                                android:textSize="15sp"
                                android:textColor="@color/text_main"/>
                            <TextView
                                android:id="@+id/tv_base_price"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹0.00"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_dark"/>
                        </LinearLayout>
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/border"/>

                        <!-- Adjusted Price Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingTop="10dp"
                            android:paddingBottom="10dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/quality_adj_price"
                                android:textSize="15sp"
                                android:textColor="@color/text_main"/>
                            <TextView
                                android:id="@+id/tv_final_price"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹0.00"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_dark"/>
                        </LinearLayout>
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/border"/>
                    </LinearLayout>

                    <!-- Total Payout (Gradient Box) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_gradient_primary"
                        android:padding="25dp"
                        android:layout_marginBottom="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/total_payment"
                            android:textSize="16sp"
                            android:textColor="#CCFFFFFF"/>
                        <TextView
                            android:id="@+id/tv_total"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹0.00"
                            android:textSize="44sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_white"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <!-- Process Payment Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_process_payment"
                        style="@style/DairyDash.Button.Success"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/btn_process_payment"
                        android:padding="14dp"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>
